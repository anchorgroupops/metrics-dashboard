# See https://help.github.com/articles/ignoring-files/ for more about ignoring files.

# dependencies
/node_modules
/.pnp
.pnp.*
.yarn/*
!.yarn/patches
!.yarn/plugins
!.yarn/releases
!.yarn/versions

# testing
/coverage

# next.js
/.next/
/out/

# production
/build

# misc
.DS_Store

# debug
npm-debug.log*
yarn-debug.log*
yarn-error.log*
.pnpm-debug.log*

# ── Secrets — never commit any of these ──────────────────────────────────────
# Env files (all variants; keep .env.example tracked).
.env
.env.*
!.env.example

# Local secret stores / credential dumps
config/secrets/
secrets/
*.secret
*.secrets
secrets.*

# Keys & certificates
*.pem
*.key
*.pfx
*.p12
*.keystore
id_rsa
id_dsa
*.cer
*.crt

# Cloud / service-account credentials
.netrc
.npmrc
credentials.json
service-account*.json
gcp-*.json
aws-credentials*
*.tfvars

# Python env
pipeline/.venv/
pipeline/venv/
.venv/
venv/
__pycache__/
*.pyc

# vercel
.vercel

# typescript
*.tsbuildinfo
next-env.d.ts
