# ============================================================================
# Anchor Group Metrics Dashboard — environment template
# ----------------------------------------------------------------------------
# Copy to `.env` (or `.env.local` for Next.js) and fill in REAL values locally.
# NEVER commit the filled-in file. In CI/production these come from GitHub
# Secrets / your host's secret store — see .github/workflows/.
# ============================================================================

# ── Database (Neon / Postgres) ───────────────────────────────────────────────
# Used by Prisma (src/lib/db.ts) and the Python pipeline.
DATABASE_URL="postgresql://user:password@host/dbname?sslmode=require"

# ── Follow Up Boss API ───────────────────────────────────────────────────────
FUB_API_KEY=""
FUB_X_SYSTEM=""
FUB_X_SYSTEM_KEY=""

# ── Follow Up Boss Web UI (Playwright CSV automation, optional) ───────────────
FUB_WEB_USER=""
FUB_WEB_PASSWORD=""
FUB_REPORT_URL=""
FUB_WEB_TIMEOUT="30000"

# ── Supabase ─────────────────────────────────────────────────────────────────
# ANON key is RLS-protected and safe to expose to browsers. The SERVICE key is
# a full-access admin secret — keep it server-side only, never in client code.
SUPABASE_URL=""
SUPABASE_ANON_KEY=""
SUPABASE_SERVICE_KEY=""

# ── Claude API (threshold research) ──────────────────────────────────────────
ANTHROPIC_API_KEY=""

# ── Email / SMTP ─────────────────────────────────────────────────────────────
SMTP_HOST="smtp.gmail.com"
SMTP_PORT="587"
SMTP_USER=""
SMTP_PASSWORD=""
EMAIL_FROM="metrics@anchorteam.com"
ADMIN_EMAIL=""

# Comma-separated FUB emails allowed into the admin dashboard.
ADMIN_EMAILS=""
