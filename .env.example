# Database (Neon PostgreSQL or any Postgres)
DATABASE_URL="postgresql://user:password@host/dbname?sslmode=require"

# Follow Up Boss API (HTTP Basic: API key as username; X-System identity now required)
FUB_API_KEY=""
FUB_X_SYSTEM=""
FUB_X_SYSTEM_KEY=""

# Zillow Preferred scraper (FUB web login — pCVR/pickup/ZHL are UI-only, no API)
ZILLOW_WEB_USER=""
ZILLOW_WEB_PASSWORD=""
ZILLOW_REPORT_URL=""          # FUB Zillow Performance Report page URL
ZILLOW_MOCK=""                # set to 1 to use synthetic rows (no browser)

# Nightly refresh
REFRESH_PERIOD=""             # YYYY-MM override; blank = current month
SLACK_WEBHOOK_URL=""          # Slack incoming webhook for refresh summaries

# NotebookLM integration (no public API yet — adapter is a no-op until set)
NOTEBOOKLM_API_KEY=""
NOTEBOOKLM_NOTEBOOK_ID=""

# Supabase (optional, for realtime features)
SUPABASE_URL=""
SUPABASE_ANON_KEY=""
SUPABASE_SERVICE_KEY=""

# Resend (email delivery)
RESEND_API_KEY=""
EMAIL_FROM="metrics@anchorteam.com"

# Admin auth
ADMIN_PASSWORD=""
NEXTAUTH_SECRET=""
