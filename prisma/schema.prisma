generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

model Agent {
  id        String   @id @default(cuid())
  fubId     String?  @unique @map("fub_id")
  name      String
  email     String   @unique
  role      String   @default("agent")
  active    Boolean  @default(true)
  teamId    String?  @map("team_id")
  createdAt DateTime @default(now()) @map("created_at")
  updatedAt DateTime @updatedAt @map("updated_at")

  team Team? @relation(fields: [teamId], references: [id], onDelete: SetNull)

  periods        AgentPeriod[]
  dailySnapshots DailySnapshot[]
  drafts         Draft[]
  zillowMetrics  ZillowMetric[]
  fubMetrics     FubMetric[]
  snapshots      PerformanceSnapshot[]

  @@index([teamId])
  @@map("agents")
}

// A team groups agents under a single crew lead.
model Team {
  id        String   @id @default(cuid())
  name      String
  slug      String   @unique
  active    Boolean  @default(true)
  createdAt DateTime @default(now()) @map("created_at")
  updatedAt DateTime @updatedAt @map("updated_at")

  crewLead CrewLead?
  agents   Agent[]

  @@map("teams")
}

// The crew lead responsible for a team. Modeled as its own record (not just an
// Agent role) because a crew lead may sit outside the producing-agent roster
// and carries team-level accountability. Optionally links to an Agent row when
// the crew lead also carries their own Zillow book of business.
model CrewLead {
  id        String   @id @default(cuid())
  fubId     String?  @unique @map("fub_id")
  name      String
  email     String   @unique
  teamId    String   @unique @map("team_id")
  agentId   String?  @unique @map("agent_id")
  createdAt DateTime @default(now()) @map("created_at")
  updatedAt DateTime @updatedAt @map("updated_at")

  team Team @relation(fields: [teamId], references: [id], onDelete: Cascade)

  @@map("crew_leads")
}

// Metrics sourced from the Zillow Preferred UI (scraper). These are NOT
// available from the FUB API: pCVR, pickup rate, and ZHL pre-approval progress
// are Zillow-UI-only. One row per agent per reporting period.
model ZillowMetric {
  id             String   @id @default(cuid())
  agentId        String   @map("agent_id")
  period         String // YYYY-MM
  pcvr           Float? // Predicted Conversion Rate (decimal 0-1)
  pickupRate     Float?   @map("pickup_rate") // decimal 0-1
  zhlPreapproval Float?   @map("zhl_preapproval") // decimal 0-1 progress to target
  csat           Float? // Best of Zillow CSAT (decimal 0-1)
  connections    Int? // raw connection count from the report
  leads          Int? // Zillow leads in the window
  source         String   @default("zillow_scraper")
  raw            Json? // full scraped row for audit / reprocessing
  scrapedAt      DateTime @default(now()) @map("scraped_at")

  agent Agent @relation(fields: [agentId], references: [id], onDelete: Cascade)

  @@unique([agentId, period])
  @@index([period])
  @@map("zillow_metrics")
}

// Metrics pulled from the Follow Up Boss API. One row per agent per period.
// Covers the activity surface FUB does expose: calls, texts, appointments,
// deals, and nurture tasks.
model FubMetric {
  id            String   @id @default(cuid())
  agentId       String   @map("agent_id")
  period        String // YYYY-MM
  calls         Int      @default(0)
  texts         Int      @default(0)
  appointments  Int      @default(0)
  deals         Int      @default(0)
  nurtureTasks  Int      @default(0) @map("nurture_tasks")
  zillowLeads   Int      @default(0) @map("zillow_leads")
  raw           Json? // endpoint response digest for audit
  pulledAt      DateTime @default(now()) @map("pulled_at")

  agent Agent @relation(fields: [agentId], references: [id], onDelete: Cascade)

  @@unique([agentId, period])
  @@index([period])
  @@map("fub_metrics")
}

// A reconciled point-in-time snapshot joining the FUB and Zillow surfaces into
// the scored view the dashboard reads. Written by the nightly refresh job.
model PerformanceSnapshot {
  id                   String   @id @default(cuid())
  agentId              String   @map("agent_id")
  period               String // YYYY-MM
  snapshotDate         String   @map("snapshot_date") // YYYY-MM-DD
  operationalReadiness Float?   @map("operational_readiness")
  overallStatus        String?  @map("overall_status")
  leaderboardPoints    Int      @default(0) @map("leaderboard_points")
  zilpiEligible        Boolean  @default(false) @map("zilpi_eligible")
  fubMetricId          String?  @map("fub_metric_id")
  zillowMetricId       String?  @map("zillow_metric_id")
  createdAt            DateTime @default(now()) @map("created_at")

  agent Agent @relation(fields: [agentId], references: [id], onDelete: Cascade)

  @@unique([agentId, snapshotDate])
  @@index([period])
  @@index([snapshotDate])
  @@map("performance_snapshots")
}

model AgentPeriod {
  id        String   @id @default(cuid())
  agentId   String   @map("agent_id")
  period    String   // YYYY-MM
  metricKey String   @map("metric_key")
  value     Float?
  createdAt DateTime @default(now()) @map("created_at")

  agent Agent @relation(fields: [agentId], references: [id], onDelete: Cascade)

  @@unique([agentId, period, metricKey])
  @@index([period])
  @@index([agentId, period])
  @@map("agent_periods")
}

model DailySnapshot {
  id           String   @id @default(cuid())
  agentId      String   @map("agent_id")
  snapshotDate String   @map("snapshot_date") // YYYY-MM-DD
  metricKey    String   @map("metric_key")
  value        Float?
  createdAt    DateTime @default(now()) @map("created_at")

  agent Agent @relation(fields: [agentId], references: [id], onDelete: Cascade)

  @@unique([agentId, snapshotDate, metricKey])
  @@index([snapshotDate])
  @@index([agentId, snapshotDate])
  @@map("daily_snapshots")
}

model Run {
  id        String    @id @default(cuid())
  source    String    // "fub", "csv", "json", "fub-daily"
  period    String?
  status    String    @default("running") // "running", "completed", "failed"
  startedAt DateTime  @default(now()) @map("started_at")
  endedAt   DateTime? @map("ended_at")
  error     String?
  meta      Json?

  @@index([status])
  @@map("runs")
}

model Draft {
  id        String    @id @default(cuid())
  agentId   String    @map("agent_id")
  period    String
  subject   String
  htmlBody  String    @map("html_body") @db.Text
  status    String    @default("pending") // "pending", "approved", "rejected", "sent"
  createdAt DateTime  @default(now()) @map("created_at")
  updatedAt DateTime  @updatedAt @map("updated_at")
  sentAt    DateTime? @map("sent_at")

  agent Agent @relation(fields: [agentId], references: [id], onDelete: Cascade)

  @@unique([agentId, period])
  @@index([status])
  @@index([period])
  @@map("drafts")
}
